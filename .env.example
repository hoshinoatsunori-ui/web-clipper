# Notion API
# https://www.notion.so/my-integrations でインテグレーションを作成して取得
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion データベースID
# データベースページのURLから取得: notion.so/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx?v=...
#                                              ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ これがDB ID
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic (Claude) API
# https://console.anthropic.com/ で取得
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# アプリのURL (Vercelデプロイ後に設定)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
